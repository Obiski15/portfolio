<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}Notification{% endblock %}</title>
  <style>
    /* Global Styles */
    body {
      margin: 0;
      padding: 0;
      background-color: #09090b;
      color: #fafafa;
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
      -webkit-font-smoothing: antialiased;
    }
    
    /* Layout */
    .wrapper {
      width: 100%;
      table-layout: fixed;
      background-color: #09090b;
      padding-bottom: 40px;
    }
    
    .container {
      max-width: 600px;
      margin: 0 auto;
      background-color: #09090b;
      border: 1px solid rgba(255, 255, 255, 0.06);
      border-radius: 12px;
      margin-top: 40px;
      padding: 40px 20px;
    }

    /* Typography */
    h1, h2, h3, h4, p {
      margin: 0;
    }

    a {
      color: #10b981;
      text-decoration: none;
    }
    
    a:hover {
      text-decoration: underline;
    }

    /* Shared Components */
    .header {
      margin-bottom: 30px;
      padding-bottom: 20px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    }
    
    .header-centered {
      margin-bottom: 30px;
      text-align: center;
    }

    .footer {
      text-align: center;
      border-top: 1px solid rgba(255, 255, 255, 0.06);
      padding-top: 20px;
      margin-top: 30px;
    }
    
    .footer-text {
      font-size: 12px;
      color: #52525b;
    }

    .button {
      display: inline-block;
      background-color: #10b981;
      color: #09090b !important;
      font-weight: 500;
      text-decoration: none;
      padding: 12px 24px;
      border-radius: 8px;
      font-size: 14px;
      margin-top: 20px;
    }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="container">
      {% block content %}{% endblock %}
      
      {% block footer %}
      <div class="footer">
        <p class="footer-text">Generated by Portfolio OS • {{ date }}</p>
      </div>
      {% endblock %}
    </div>
  </div>
</body>
</html>
