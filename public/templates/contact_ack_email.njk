{% extends "base.njk" %}

{% block title %}Message Received{% endblock %}

{% block content %}
<div class="header-centered">
  <h2 style="color: #10b981; font-weight: 600; font-size: 24px; letter-spacing: -0.5px;">
    Message Received
  </h2>
  <p style="margin-top: 10px; color: #a1a1aa; font-size: 15px; line-height: 1.6;">
    Hi {{ name }}, thanks for reaching out.
  </p>
</div>

<!-- Body -->
<div style="background-color: #18181b; padding: 30px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.04); margin-bottom: 30px;">
  <p style="margin-bottom: 15px; font-size: 15px; line-height: 1.6; color: #e4e4e7;">
    I've successfully received your message and will review it shortly. I typically respond within 24-48 hours.
  </p>
  <p style="font-size: 15px; line-height: 1.6; color: #e4e4e7;">
    In the meantime, feel free to check out more of my work or connect with me on LinkedIn.
  </p>
</div>

<!-- Custom Footer for Ack Email -->
<div style="text-align: center; border-top: 1px solid rgba(255,255,255,0.06); padding-top: 30px;">
  <p style="margin-bottom: 5px; font-size: 14px; color: #fafafa; font-weight: 500;">
    Obi Emmanuel
  </p>
  <p style="font-size: 12px; color: #71717a;">
    Full-Stack Product Engineer
  </p>
</div>
{% endblock %}

{% block footer %}
<!-- Override base footer with an empty block since we use a custom sign-off above -->
{% endblock %}