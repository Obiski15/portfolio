{# email-template.njk #}
<div style="font-family: 'Courier New', Courier, monospace; background-color: #0d1117; color: #c9d1d9; padding: 20px; border: 1px solid #30363d; border-radius: 8px;">
  
  <h2 style="color: #00e475; border-bottom: 1px solid #00e475; padding-bottom: 10px;">
    [PORTFOLIO_OS] // NEW_INQUIRY
  </h2>

  <div style="margin: 20px 0;">
    <p><strong>FROM:</strong> {{ email }}</p>
    <p><strong>TYPE:</strong> <span style="text-transform: uppercase;">{{ request_type }}</span></p>
    <p><strong>PRIORITY:</strong> 
      {% if priority == 'high' %}
        <span style="color: #ef4444; font-weight: bold;">[!!!] HIGH</span>
      {% elseif priority == 'medium' %}
        <span style="color: #eab308;">[!] MEDIUM</span>
      {% else %}
        <span style="color: #00e475;">[ ] LOW</span>
      {% endif %}
    </p>
  </div>

  <div style="background-color: #161b22; padding: 15px; border-left: 4px solid #00e475; border-radius: 4px;">
    <p style="margin-top: 0; color: #8b949e; font-size: 12px;">// MESSAGE_START</p>
    <p style="white-space: pre-wrap; line-height: 1.6;">{{ message }}</p>
    <p style="margin-bottom: 0; color: #8b949e; font-size: 12px;">// MESSAGE_END</p>
  </div>

  <p style="font-size: 10px; color: #484f58; margin-top: 30px; text-align: center;">
    SYSTEM_TIMESTAMP: {{ date }}
  </p>
</div>