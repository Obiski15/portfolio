{% extends "base.njk" %}

{% block title %}New Contact Request{% endblock %}

{% block content %}
<div class="header">
  <h2 style="color: #10b981; font-weight: 600; font-size: 20px; letter-spacing: -0.5px;">
    New Contact Request
  </h2>
  <p style="margin-top: 5px; color: #a1a1aa; font-size: 14px;">
    You received a new message via your portfolio.
  </p>
</div>

<!-- Meta Info -->
<div style="margin-bottom: 30px; background-color: rgba(255,255,255,0.03); padding: 20px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.04);">
  <p style="margin-bottom: 10px; font-size: 14px;">
    <span style="color: #71717a; width: 60px; display: inline-block;">Name:</span> 
    <strong style="color: #fafafa;">{{ name }}</strong>
  </p>
  <p style="margin: 0; font-size: 14px;">
    <span style="color: #71717a; width: 60px; display: inline-block;">Email:</span> 
    <a href="mailto:{{ email }}">{{ email }}</a>
  </p>
</div>

<!-- Message Body -->
<div style="margin-bottom: 30px;">
  <h3 style="margin-bottom: 15px; color: #71717a; font-size: 12px; text-transform: uppercase; letter-spacing: 1px;">Message</h3>
  <div style="background-color: #18181b; padding: 24px; border-radius: 8px; border-left: 3px solid #10b981;">
    <p style="white-space: pre-wrap; line-height: 1.6; font-size: 15px; color: #e4e4e7;">{{ message }}</p>
  </div>
</div>
{% endblock %}